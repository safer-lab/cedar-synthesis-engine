# Cedar Synthesis Engine — environment template.
# Copy to `.env` and fill in. `.env` is gitignored.
#
# Usage:
#   uv run --env-file .env python eval_harness.py --scenario <path> --no-review
#
# Or, in a shell:
#   set -a && source .env && set +a
#   uv run python eval_harness.py --scenario <path> --no-review

# Anthropic API key for Phase 1 (planner) and Phase 2 (synthesizer) LLM calls.
# Required by eval_harness.py, orchestrator.py (--translate), review.py.
ANTHROPIC_API_KEY=sk-ant-...
